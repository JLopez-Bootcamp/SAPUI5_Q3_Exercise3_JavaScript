{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start exercise3",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "windows": {
        "runtimeExecutable": "npx.cmd"
      },
      "runtimeArgs": [
        "fiori",
        "run"
      ],
      "args": [
        "--open",
        "test/flp.html#app-preview"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std",
      "env": {
        "DEBUG": "--inspect",
        "FIORI_TOOLS_URL_PARAMS": "sap-ui-xx-viewCache=false",
        "run.config": "{\"handlerId\":\"fiori_tools\",\"runnableId\":\"/home/user/projects/exercise3\"}"
      }
    },
    {
      "name": "Start exercise3 Local",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "windows": {
        "runtimeExecutable": "npx.cmd"
      },
      "runtimeArgs": [
        "fiori",
        "run"
      ],
      "args": [
        "--config",
        "./ui5-local.yaml",
        "--open",
        "test/flp.html#app-preview"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std",
      "env": {
        "FIORI_TOOLS_URL_PARAMS": "sap-ui-xx-viewCache=false",
        "run.config": "{\"handlerId\":\"fiori_tools\",\"runnableId\":\"/home/user/projects/exercise3\"}"
      }
    },
    {
      "name": "Launch Activity 1",
      "program": "${workspaceFolder}/js_activities/activity1.js",
      "request": "launch",
      "skipFiles": [
        "<node_internals/**>"
      ],
      "type": "node"
    },
    {
      "name": "Launch Activity 2",
      "program": "${workspaceFolder}/js_activities/activity2.js",
      "request": "launch",
      "skipFiles": [
        "<node_internals/**>"
      ],
      "type": "node"
    },
    {
      "name": "Launch Activity 3",
      "program": "${workspaceFolder}/js_activities/activity3.js",
      "request": "launch",
      "skipFiles": [
        "<node_internals/**>"
      ],
      "type": "node"
    },
    {
      "name": "Launch Activity 4",
      "program": "${workspaceFolder}/js_activities/activity4.js",
      "request": "launch",
      "skipFiles": [
        "<node_internals/**>"
      ],
      "type": "node"
    }
  ]
}